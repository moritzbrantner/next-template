# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next_template?schema=public"

# App/auth base URLs
AUTH_SECRET="replace-with-a-long-random-secret"
SITE_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Account lifecycle email delivery
EMAIL_PROVIDER="console"
EMAIL_FROM="no-reply@example.com"
MAILPIT_BASE_URL="http://127.0.0.1:8025"

# Profile image object storage
PROFILE_IMAGE_STORAGE_BUCKET="profile-images"
PROFILE_IMAGE_STORAGE_REGION="auto"
PROFILE_IMAGE_STORAGE_ENDPOINT="https://example.r2.cloudflarestorage.com"
PROFILE_IMAGE_STORAGE_ACCESS_KEY_ID="replace-me"
PROFILE_IMAGE_STORAGE_SECRET_ACCESS_KEY="replace-me"
PROFILE_IMAGE_PUBLIC_BASE_URL="https://cdn.example.com/profile-images"
PROFILE_IMAGE_STORAGE_FORCE_PATH_STYLE="false"

# Observability and internal jobs
LOG_LEVEL="debug"
INTERNAL_CRON_SECRET="replace-with-an-internal-cron-secret"
ANALYTICS_ENABLED="true"
