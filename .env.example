# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next_template?schema=public"

# App/auth base URLs
AUTH_SECRET="replace-with-a-long-random-secret"
SITE_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""
X_CLIENT_ID=""
X_CLIENT_SECRET=""

# Account lifecycle email delivery
EMAIL_PROVIDER="console"
EMAIL_FROM="no-reply@example.com"
MAILPIT_BASE_URL="http://127.0.0.1:8025"

# Profile image object storage
PROFILE_IMAGE_STORAGE_BUCKET="profile-images"
PROFILE_IMAGE_STORAGE_REGION="us-east-1"
PROFILE_IMAGE_STORAGE_ENDPOINT="http://127.0.0.1:9000"
PROFILE_IMAGE_STORAGE_ACCESS_KEY_ID="minioadmin"
PROFILE_IMAGE_STORAGE_SECRET_ACCESS_KEY="minioadmin"
PROFILE_IMAGE_PUBLIC_BASE_URL="http://127.0.0.1:9000/profile-images"
PROFILE_IMAGE_STORAGE_FORCE_PATH_STYLE="true"

# Local MinIO object storage for uploads
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_BUCKET="profile-images"
MINIO_API_PORT="9000"
MINIO_CONSOLE_PORT="9001"

# Observability and internal jobs
LOG_LEVEL="debug"
INTERNAL_CRON_SECRET="replace-with-an-internal-cron-secret"
ANALYTICS_ENABLED="true"
