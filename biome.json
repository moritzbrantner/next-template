{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "enabled": true,
    "includes": [
      "**",
      "!.next/**",
      "!out/**",
      "!build/**",
      "!dist/**",
      "!coverage/**",
      "!packages/**",
      "!next-env.d.ts",
      "!vendor/**"
    ],
    "rules": {
      "recommended": false,
      "a11y": {
        "noAriaUnsupportedElements": "warn",
        "useAltText": "warn",
        "useAriaPropsForRole": "warn",
        "useAriaPropsSupportedByRole": "warn",
        "useValidAriaProps": "warn",
        "useValidAriaValues": "warn"
      },
      "complexity": {
        "noArguments": "error",
        "noUselessTypeConstraint": "error"
      },
      "correctness": {
        "noChildrenProp": "error",
        "noNextAsyncClientComponent": "warn",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "error",
        "useJsxKeyInIterable": "error"
      },
      "performance": {
        "noImgElement": "warn",
        "noUnwantedPolyfillio": "warn",
        "useGoogleFontPreconnect": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtmlWithChildren": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noHeadElement": "warn",
        "noNamespace": "error",
        "useArrayLiterals": "error",
        "useAsConstAssertion": "error",
        "useConst": "error"
      },
      "suspicious": {
        "noCommentText": "error",
        "noDocumentImportInPage": "error",
        "noDuplicateJsxProps": "error",
        "noExplicitAny": "error",
        "noExtraNonNullAssertion": "error",
        "noHeadImportInDocument": "error",
        "noImportAssign": "error",
        "noMisleadingInstantiator": "error",
        "noNonNullAssertedOptionalChain": "error",
        "noUnsafeDeclarationMerging": "error",
        "noVar": "error",
        "useGetterReturn": "error",
        "useGoogleFontDisplay": "warn",
        "useNamespaceKeyword": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": {
          "style": {
            "noNamespace": "off"
          }
        }
      }
    },
    {
      "includes": [
        "app/**/*.{ts,tsx}",
        "components/**/*.{ts,tsx}",
        "src/**/*.{ts,tsx}",
        "scripts/**/*.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@features/*",
                      "@stores/*",
                      "@services/*",
                      "@/features/*",
                      "@/stores/*",
                      "@/lib/services/*"
                    ],
                    "message": "Use the current module boundaries instead of deprecated feature, store, or service aliases."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/domain/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/*", "@/components/*"],
                    "message": "Domain code must not import app or component layer modules directly."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/db/**/*.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": ["@/app/*", "@/components/*", "@/src/domain/*", "@/src/profile/*"],
                    "message": "Database code must stay isolated from app, UI, domain, and profile layers."
                  }
                ]
              }
            }
          }
        }
      }
    }
  ]
}
