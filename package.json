{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/app-pack", "packages/app-pack-react"],
  "description": "Next.js platform scaffold with a standalone repo manifest, external shared packages, and internal app-pack seams",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-test-db.sh",
    "dev:app": "bun run packages:build && next dev",
    "build": "bun run packages:build && next build",
    "build:gh-pages": "bun run packages:build && bun ./scripts/build-gh-pages.mjs",
    "build:staging": "bun run build:gh-pages",
    "start": "next start",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "packages:build": "bun ./scripts/run-workspace-command.mjs build",
    "packages:lint": "bun ./scripts/run-workspace-command.mjs lint",
    "packages:typecheck": "bun ./scripts/run-workspace-command.mjs typecheck",
    "packages:test": "bun ./scripts/run-workspace-command.mjs test",
    "typecheck": "tsc --noEmit",
    "ci:verify": "bun run lint && bun run typecheck && bun run packages:lint && bun run packages:typecheck && bun run packages:test && bun run db:check && bun run build",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:setup": "./scripts/ci/bootstrap-e2e-db.sh",
    "test:e2e:teardown": "./scripts/ci/bootstrap-e2e-db.sh --teardown",
    "test:e2e:auth": "playwright test tests/e2e/authentication.spec.ts",
    "db:seed:test-users": "bun ./scripts/seed-test-users.ts",
    "test:unit": "vitest run tests/unit apps/showcase/tests",
    "checks:nightly": "./scripts/ci/tier-nightly.sh",
    "checks:beta": "./scripts/ci/tier-beta.sh",
    "checks:main": "./scripts/ci/tier-main.sh",
    "checks:all": "./scripts/ci/tier-all.sh",
    "db:schema:generate": "bun ./scripts/generate-db-schema.ts",
    "jobs:work": "bun ./scripts/run-jobs.ts --watch"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@auth/drizzle-adapter": "^1.11.1",
    "@tanstack/react-table": "^8.21.3",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@moritzbrantner/app-pack": "workspace:*",
    "@moritzbrantner/app-pack-react": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "@mdx-js/mdx": "^3.1.1",
    "@moritzbrantner/storytelling": "file:../platform-packages/packages/storytelling",
    "@moritzbrantner/ui": "file:../platform-packages/packages/ui",
    "@next/mdx": "^16.2.3",
    "@react-email/components": "1.0.8",
    "@react-three/fiber": "^9.5.0",
    "@remotion/player": "^4.0.447",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "dexie": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "motion": "^12.35.2",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.9.0",
    "recharts": "^3.8.1",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.447",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "swapy": "^1.0.5",
    "tailwind-merge": "^3.4.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@moritzbrantner/ui": "file:../platform-packages/packages/ui"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@playwright/test": "^1.58.2",
    "@react-email/preview-server": "5.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@unlighthouse/cli": "^0.17.7",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "puppeteer": "^24.40.0",
    "react-email": "5.2.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.3.12"
}
