{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js platform scaffold with a standalone repo manifest, external shared packages, and internal app-pack seams",
  "workspaces": [
    "packages/app-pack",
    "packages/app-pack-react"
  ],
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-test-db.sh",
    "dev:app": "bun run packages:build && next dev",
    "build": "bun run packages:build && next build",
    "build:app": "next build",
    "build:gh-pages": "bun run packages:build && bun ./scripts/build-gh-pages.mjs",
    "build:staging": "bun run build:gh-pages",
    "start": "next start",
    "storybook": "NEXT_DEPLOY_TARGET=gh-pages storybook dev -p 6006",
    "storybook:build": "NEXT_DEPLOY_TARGET=gh-pages storybook build --quiet",
    "test": "bun run test:unit",
    "test:storybook": "bun run storybook:build && bun ./scripts/ci/audit-storybook-a11y.mjs && rm -rf storybook-static",
    "bench": "vitest bench --run",
    "bench:ci": "mkdir -p .generated/benchmarks && vitest bench --run --outputJson=.generated/benchmarks/latest.json",
    "bench:unlighthouse": "bun run build:gh-pages",
    "verify": "bun run hygiene && bun run checks:main",
    "lint:format": "oxfmt --check .",
    "lint:semantic": "eslint .",
    "lint": "bun run lint:format && bun run lint:semantic",
    "lint:fix": "oxfmt --write .",
    "format": "bun run lint:fix",
    "format:check": "bun run lint:format",
    "hygiene": "./scripts/check_repo_hygiene.sh",
    "packages:build": "bun ./scripts/run-workspace-command.mjs build",
    "packages:lint": "bun ./scripts/run-workspace-command.mjs lint",
    "packages:typecheck": "bun ./scripts/run-workspace-command.mjs typecheck",
    "packages:test": "bun run packages:build && bun ./scripts/run-workspace-command.mjs test",
    "packages:publint": "bun run packages:build && publint packages/app-pack && publint packages/app-pack-react",
    "supply-chain:audit": "bun audit --audit-level=critical",
    "supply-chain:audit:all": "bun audit",
    "supply-chain": "bun run supply-chain:audit && bun run packages:publint",
    "typecheck": "bun run packages:build && tsc --noEmit",
    "ci:verify": "bun run lint && bun run typecheck && bun run packages:lint && bun run packages:typecheck && bun run packages:test && bun run db:check && bun run build",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:integration": "bun run packages:build && vitest run .integration.test.",
    "test:unlighthouse": "bun run bench:unlighthouse",
    "playwright": "playwright test --ui --ui-host=127.0.0.1",
    "test:e2e": "playwright test",
    "test:e2e:setup": "./scripts/ci/bootstrap-e2e-db.sh",
    "test:e2e:teardown": "./scripts/ci/bootstrap-e2e-db.sh --teardown",
    "test:e2e:auth": "playwright test authentication.e2e.spec.ts",
    "db:seed:test-users": "bun ./scripts/seed-test-users.ts",
    "db:seed:test-profile-images": "bun ./scripts/seed-test-profile-images.ts",
    "test:unit": "vitest run .unit.test.",
    "checks:nightly": "./scripts/ci/tier-nightly.sh",
    "checks:beta": "./scripts/ci/tier-beta.sh",
    "checks:main": "./scripts/ci/tier-main.sh",
    "checks:all": "./scripts/ci/tier-all.sh",
    "db:schema:generate": "bun ./scripts/generate-db-schema.ts",
    "jobs:work": "bun ./scripts/run-jobs.ts --watch",
    "services:up": "docker compose up -d postgres mailpit redis minio",
    "services:down": "docker compose stop postgres mailpit redis minio",
    "services:clean": "docker compose down -v --remove-orphans",
    "services:ps": "docker compose ps",
    "check:hygiene": "bash scripts/check_repo_hygiene.sh",
    "test:with-services": "COMPOSE_SERVICES=\"postgres mailpit redis minio\" bash scripts/run-with-compose-services.sh bun run test:e2e"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1050.0",
    "@mdx-js/mdx": "^3.1.1",
    "@moritzbrantner/app-pack": "workspace:*",
    "@moritzbrantner/app-pack-react": "workspace:*",
    "@moritzbrantner/ui": "^0.10.0",
    "@next/mdx": "^16.2.6",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@react-three/fiber": "^9.6.1",
    "@remotion/player": "4.0.464",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.11",
    "dexie": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.7",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "redis": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "4.0.464",
    "swapy": "^1.0.5",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.7",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@unlighthouse/cli": "^0.17.9",
    "axe-core": "^4.12.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.51.0",
    "publint": "^0.3.21",
    "puppeteer": "^25.0.4",
    "storybook": "^10.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.13",
    "vitest": "4.1.7"
  },
  "packageManager": "bun@1.3.14"
}
