{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "description": "TanStack Start application with auth, admin examples, and Drizzle/Postgres persistence",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-test-db.sh",
    "dev:app": "vite dev",
    "prebuild": "node scripts/generate-sitemap.ts",
    "build": "vite build",
    "start": "node ./scripts/serve-prod.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ci:verify": "pnpm run lint && pnpm run typecheck && pnpm run db:check && pnpm run build",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:setup": "./scripts/ci/bootstrap-e2e-db.sh",
    "test:e2e:teardown": "./scripts/ci/bootstrap-e2e-db.sh --teardown",
    "test:e2e:auth": "playwright test tests/e2e/authentication.spec.ts",
    "db:seed:test-users": "tsx ./scripts/seed-test-users.ts",
    "test:unit": "vitest run tests/unit",
    "checks:nightly": "./scripts/ci/tier-nightly.sh",
    "checks:beta": "./scripts/ci/tier-beta.sh",
    "checks:main": "./scripts/ci/tier-main.sh",
    "checks:all": "./scripts/ci/tier-all.sh",
    "db:schema:generate": "tsx ./scripts/generate-db-schema.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@react-email/components": "1.0.8",
    "@react-three/fiber": "^9.5.0",
    "@remotion/player": "^4.0.447",
    "@tanstack/react-router": "^1.168.10",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/react-start": "^1.167.16",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.35.2",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "remotion": "^4.0.447",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@react-email/preview-server": "5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "react-email": "5.2.8",
    "srvx": "^0.11.14",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0"
}
