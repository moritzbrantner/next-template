{
  "name": "next-template",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js application with auth, admin examples, and Drizzle/Postgres persistence",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev-with-test-db.sh",
    "dev:app": "next dev",
    "build": "next build",
    "build:gh-pages": "node scripts/build-gh-pages.mjs",
    "build:staging": "bun run build:gh-pages",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ci:verify": "bun run lint && bun run typecheck && bun run db:check && bun run build",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:setup": "./scripts/ci/bootstrap-e2e-db.sh",
    "test:e2e:teardown": "./scripts/ci/bootstrap-e2e-db.sh --teardown",
    "test:e2e:auth": "playwright test tests/e2e/authentication.spec.ts",
    "db:seed:test-users": "node --import tsx ./scripts/seed-test-users.ts",
    "test:unit": "vitest run tests/unit",
    "checks:nightly": "./scripts/ci/tier-nightly.sh",
    "checks:beta": "./scripts/ci/tier-beta.sh",
    "checks:main": "./scripts/ci/tier-main.sh",
    "checks:all": "./scripts/ci/tier-all.sh",
    "db:schema:generate": "node --import tsx ./scripts/generate-db-schema.ts",
    "jobs:work": "node --import tsx ./scripts/run-jobs.ts --watch"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@mdx-js/mdx": "^3.1.1",
    "@next/mdx": "^16.2.3",
    "@react-email/components": "1.0.8",
    "@react-three/fiber": "^9.5.0",
    "@remotion/player": "^4.0.447",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "motion": "^12.35.2",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remotion": "^4.0.447",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@react-email/preview-server": "5.2.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@unlighthouse/cli": "^0.17.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.2",
    "puppeteer": "^24.40.0",
    "react-email": "5.2.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "bun@1.3.12"
}
