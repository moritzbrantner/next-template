{
  "name": "@moritzbrantner/storytelling",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moritzbrantner/next-template.git",
    "directory": "packages/storytelling"
  },
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./remotion": {
      "types": "./src/remotion.tsx",
      "import": "./src/remotion.tsx"
    },
    "./three": {
      "types": "./src/three.tsx",
      "import": "./src/three.tsx"
    }
  },
  "peerDependencies": {
    "@react-three/fiber": "^9.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.379",
    "three": "^0.180.0"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": {
      "optional": true
    },
    "remotion": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "dependencies": {
    "motion": "^12.35.0"
  },
  "devDependencies": {
    "@react-three/fiber": "^9.4.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remotion": "^4.0.379",
    "three": "^0.180.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup src/index.ts src/remotion.tsx src/three.tsx --format esm --dts --clean --out-dir dist",
    "lint": "bun ../../scripts/verify-package-imports.mjs ./src @/ next/ next-intl",
    "typecheck": "tsc --noEmit",
    "test": "cd ../.. && vitest run packages/storytelling/tests/storytelling.test.tsx"
  }
}
