{
  "name": "{{ project_slug }}",
  "version": "0.1.0",
  "private": true,
  "description": "{{ project_description }}",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
